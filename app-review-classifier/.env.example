# =============================================================
#  .env.example  —  실제 사용 시 이 파일을 .env로 복사해 값 입력
#  cp .env.example .env   (또는 Windows: copy .env.example .env)
# =============================================================

# ── MLflow ────────────────────────────────────────────────────
# 로컬 SQLite (기본값, ngrok 사용 전)
# MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# ngrok으로 MLflow 서버를 외부 공개한 뒤 아래 URL로 교체
MLFLOW_TRACKING_URI=https://xxxx-xxxx-xxxx.ngrok-free.app

# ── 모델 서빙 ─────────────────────────────────────────────────
CHAMPION_MODEL_URI=models:/review-classifier@champion
CHALLENGER_MODEL_URI=models:/review-classifier@challenger

# rules = 키워드 더미 분류기 / ml = MLflow champion 모델 사용
MODEL_MODE=rules

# ── 카나리 배포 ───────────────────────────────────────────────
CANARY_ENABLED=false
CANARY_RATIO=0.25

# ── Drift 감지 / 재학습 트리거 ────────────────────────────────
LOW_CONFIDENCE_THRESHOLD=0.65
LOW_CONFIDENCE_LIMIT=5

# ── GitHub Issue 자동 생성 (재학습 알림) ─────────────────────
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GH_REPO=your-username/app-review-classifier

# ── Google Sheets DB ─────────────────────────────────────────
# 시트 지정: 이름(권장) 또는 ID 중 하나만 설정하면 됨
GOOGLE_SHEET_NAME=앱리뷰분류기          # 스프레드시트 이름 (강의 방식 — 권장)
GOOGLE_CREDENTIALS_FILE=credentials.json
MODEL_MODE=rules

# 인증 방법 1 (권장 — Render/CI): 서비스계정 JSON 전체를 한 줄 문자열로
#   생성: python -c "import json; print(json.dumps(json.load(open('credentials.json'))))"
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# 인증 방법 2 (로컬 개발): credentials.json 파일 경로
GOOGLE_CREDENTIALS_FILE=credentials.json
